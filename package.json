{
  "name": "pi-agent-review",
  "version": "0.3.0",
  "description": "A pi coding-agent extension that reviews every tool call and tool output with an LLM reviewer, hard-denies secret access, and gates risky actions behind user approval.",
  "type": "module",
  "license": "MIT",
  "author": "Everett Morgan <everett@ejmlabs.com>",
  "homepage": "https://github.com/everettmorgan/pi-agent-review#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everettmorgan/pi-agent-review.git"
  },
  "bugs": {
    "url": "https://github.com/everettmorgan/pi-agent-review/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "agent",
    "security",
    "code-review",
    "guardrails"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "xo",
    "lint:fix": "xo --fix"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "safe-stable-stringify": "^2.5.0",
    "typebox": "^1.3.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "xo": "^3.0.2"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
